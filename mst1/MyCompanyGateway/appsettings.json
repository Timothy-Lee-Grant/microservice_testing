{
  "Logging": {
    "LogLevel": { "Default": "Information" }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "test-route": {
        "ClusterId": "test-cluster",
        "Match": {
          "Path": "/proxyme/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/proxyme" }
        ]
      }
    },
    "Clusters": {
      "test-cluster": {
        "Destinations": {
          "external-api": {
            "Address": "https://httpbin.org/"
          }
        }
      }
    }
  }
}